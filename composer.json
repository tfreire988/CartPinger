{
    "name": "telmofreire/whatscom",
    "description": "WhatsApp commerce plugin for WooCommerce",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "wp-coding-standards/wpcs": "^3.1",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "automattic/vipwpcs": "^3.0",
        "phpstan/phpstan": "^1.11",
        "szepeviktor/phpstan-wordpress": "^1.3",
        "php-stubs/woocommerce-stubs": "^9.0",
        "phpunit/phpunit": "^9.6",
        "yoast/phpunit-polyfills": "^2.0",
        "10up/wp_mock": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "WhatsCom\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WhatsCom\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "platform": {
            "php": "8.2"
        }
    },
    "scripts": {
        "lint": "phpcs --standard=phpcs.xml.dist src/ whatscom.php",
        "lint:fix": "phpcbf --standard=phpcs.xml.dist src/ whatscom.php",
        "stan": "phpstan analyse --configuration=phpstan.neon.dist",
        "test": "phpunit --configuration=phpunit.xml.dist",
        "all-checks": [
            "@lint",
            "@stan",
            "@test"
        ]
    }
}
